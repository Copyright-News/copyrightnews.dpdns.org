{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "copyrightnews",
  "compatibility_date": "2026-06-02",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [
      "build.js",
      "package.json",
      "package-lock.json",
      "content",
      "node_modules",
      "CNAME",
      ".gitignore",
      ".git"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
